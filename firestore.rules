rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Polls ────────────────────────────────────────────────────────────────
    match /polls/{pollId} {
      // Public polls are readable by everyone; private polls only by their creator.
      allow read: if !resource.data.isPrivate
                  || (request.auth != null && request.auth.uid == resource.data.createdBy);

      // Only authenticated users may create polls.
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // The creator may fully update their own poll.
      // Any authenticated user may flip status to 'ended' once the poll has expired
      // (client-side auto-expiry feature), but may not touch any other fields.
      allow update: if (request.auth != null && request.auth.uid == resource.data.createdBy)
                    || (
                      request.auth != null
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                      && request.resource.data.status == 'ended'
                      && resource.data.endsAt < request.time
                    );

      // Only the creator may delete their poll.
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // ── Votes ────────────────────────────────────────────────────────────────
    match /votes/{voteId} {
      // Only the voter themselves may read their own vote record.
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      // Any authenticated user may cast a vote.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Votes are immutable once cast.
      allow update, delete: if false;
    }

    // ── Schedule votes ───────────────────────────────────────────────────────
    match /schedule_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Ranking votes ────────────────────────────────────────────────────────
    match /ranking_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Priority votes ───────────────────────────────────────────────────────
    match /priority_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Own profile: full read/write.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Other authenticated users may read profiles for the email-lookup feature
      // (used when inviting contacts to polls). Sensitive fields like fcmToken are
      // stripped at the application layer in getUserByEmail().
      allow read: if request.auth != null;
    }

    // Contacts subcollection — only the owning user.
    match /users/{userId}/contacts/{contactId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── FCM push queue ────────────────────────────────────────────────────────
    // Only authenticated clients may enqueue a push notification.
    // Reading, updating, and deleting is reserved for the Cloud Function (Admin SDK).
    match /push_queue/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
