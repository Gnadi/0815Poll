rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Polls ────────────────────────────────────────────────────────────────
    match /polls/{pollId} {
      // Public polls are readable by everyone; private polls only by their creator.
      allow read: if !resource.data.isPrivate
                  || (request.auth != null && request.auth.uid == resource.data.createdBy);

      // Authenticated users may create polls (createdBy must match their uid).
      // Unauthenticated users may also create polls; createdBy must be null.
      // Custom polls are restricted to authenticated users in the app layer (CreateCustom.tsx).
      allow create: if (request.auth != null && request.resource.data.createdBy == request.auth.uid)
                    || (request.auth == null && request.resource.data.createdBy == null);

      // Allowed poll updates:
      // 1. Creator can change anything.
      // 2. Anyone can increment vote counts on an active poll (castVote transaction).
      // 3. Anyone can flip status to 'ended' once the poll has expired (client auto-expiry).
      allow update: if
        (request.auth != null && request.auth.uid == resource.data.createdBy)
        || (
          resource.data.status == 'active'
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['options', 'locations', 'timeSlots', 'totalVotes'])
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'ended'
          && resource.data.endsAt < request.time
        );

      // Only the creator may delete their poll.
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // ── Votes ────────────────────────────────────────────────────────────────
    match /votes/{voteId} {
      // Only the voter themselves may read their own vote record (anonymous votes are unreadable).
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      // Authenticated users must match userId; anonymous users must set userId to null.
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid)
                    || (request.auth == null && request.resource.data.userId == null);

      // Votes are immutable once cast.
      allow update, delete: if false;
    }

    // ── Schedule votes ───────────────────────────────────────────────────────
    match /schedule_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid)
                    || (request.auth == null && request.resource.data.userId == null);
      allow update, delete: if false;
    }

    // ── Ranking votes ────────────────────────────────────────────────────────
    match /ranking_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid)
                    || (request.auth == null && request.resource.data.userId == null);
      allow update, delete: if false;
    }

    // ── Priority votes ───────────────────────────────────────────────────────
    match /priority_votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid)
                    || (request.auth == null && request.resource.data.userId == null);
      allow update, delete: if false;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Own profile: full read/write.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Other authenticated users may read profiles for the email-lookup feature
      // (used when inviting contacts to polls). Sensitive fields like fcmToken are
      // stripped at the application layer in getUserByEmail().
      allow read: if request.auth != null;
    }

    // Contacts subcollection — only the owning user.
    match /users/{userId}/contacts/{contactId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── FCM push queue ────────────────────────────────────────────────────────
    // Only authenticated clients may enqueue a push notification.
    // Reading, updating, and deleting is reserved for the Cloud Function (Admin SDK).
    match /push_queue/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
